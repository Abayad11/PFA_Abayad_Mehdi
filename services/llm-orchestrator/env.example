# Service Configuration
SERVICE_NAME=llm-orchestrator
SERVICE_PORT=8002
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO

# DeepSeek R1 Model Configuration
MODEL_NAME=deepseek-ai/deepseek-r1
MODEL_PATH=/models/deepseek-r1-medical-orchestrator
USE_LORA=true
LORA_ADAPTER_PATH=/models/lora-adapters/medical-orchestrator
QUANTIZATION=int8
MAX_LENGTH=4096
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50

# Specialized LLM Services
LLM_VISION_URL=http://llm-vision:8003
LLM_TEXT_URL=http://llm-text:8004
LLM_FHIR_URL=http://llm-fhir:8005
LLM_RESEARCH_URL=http://llm-research:8006

# Database Configuration (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/abhar_sante
VECTOR_DIMENSION=768

# Redis Configuration (for caching and rate limiting)
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# RAG Configuration
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# Security
JWT_SECRET=your-secret-key-change-in-production
API_KEY_HEADER=X-API-Key

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_METRICS=true

# Guardrails
MAX_TOKENS_PER_REQUEST=2048
RATE_LIMIT_PER_MINUTE=60
ENABLE_CONTENT_FILTER=true
ENABLE_MEDICAL_VALIDATION=true
